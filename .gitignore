# ignore personal and environment-specific files
resume-workspace.code-workspace

#ignore user-specific 
users/

#ignor logs
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Environment variables
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Docker persistent data (runtime only, not in repo)
/data/

# Internal design docs (personal reference, not for public repo)
docs/

# Byte-compiled / cached
*.pyo
*.pdb

#ignore generated Docs 
*.doc
*.pdf
